             Some(node) => node,
             None => {
-                // An execution witness can include an account leaf (with non-empty storageRoot),
-                // but omit its entire storage trie when that account's storage was
-                // NOT touched during the block.
+                // The witness can include an account leaf (non-empty storageRoot) yet omit its
+                // storage trie, when the witness-builder's execution didn't touch that account's
+                // storage. Insert a Digest of the declared storage_root: if OUR execution only
+                // changes the account (balance/nonce) and doesn't touch its storage, `update()`
+                // then recomputes the correct storage_root (a Digest hashes to itself). Without
+                // this the entry defaults to an EMPTY trie → wrong storage_root → wrong state
+                // root. (If our execution DOES modify such an account's storage, the Digest can't
+                // be inserted into and the run falls back to getProof.)
+                storage_tries.insert(hashed_address, MptNodeData::Digest(storage_root).into());
                 continue;
             }
         };
