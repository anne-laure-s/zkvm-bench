diff --git a/crates/mpt/src/execution_witness.rs b/crates/mpt/src/execution_witness.rs
index 48cb0d1..ce6951c 100644
--- a/crates/mpt/src/execution_witness.rs
+++ b/crates/mpt/src/execution_witness.rs
@@ -49,9 +49,15 @@ pub(crate) fn build_validated_tries(
