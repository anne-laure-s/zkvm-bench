#!/usr/bin/env bash
#
# run — dispatcher for the SP1 proving pipeline.
#
# Two kinds of commands:
#   * PRODUCERS (guest-aware): build the ELF / generate the input. They take a
#     GUEST and its params, because building/generating is guest-specific.
#   * CONSUMERS (generic, file-based): prove / verify operate on explicit
#     artifact PATHS — they never regenerate anything, so they take no guest
#     params. This makes "what gets proved" unambiguous.
#
# Producers (guests/<name>/guest.sh provides build_elf / gen_input / decode_pv):
#   ./run build-elf GUEST=<name> [KEY=VALUE ...]        -> ../../guests/<name>/<name>.elf
#   ./run gen-input GUEST=<name> [KEY=VALUE ...] [NO_REPORT=1]  -> ../../guests/<name>/inputs/<tag>.bin
#       (by default, if the ELF + runner exist, also writes the execution
#        report next to the input; NO_REPORT=1 skips that step)
#   ./run decode-pv GUEST=<name> PV=<path>              (pretty-print public values)
#
# Consumers (explicit paths, no GUEST):
#   ./run execute ELF=<path> INPUT=<path>            (local CPU run -> rich report + pv)
#   ./run prove   ELF=<path> INPUT=<path> REMOTE=user@host [PORT=p] [MODE=m]   (single-box: SP1_PROVER default cuda)
#   ./run verify  ELF=<path> INPUT=<path> PROOF=<path>
#
# Uniform cluster-prove (guest-aware; driven by cli/prove-farm — resolves the guest's ELF+witness,
# forces the NETWORK backend = 16-GPU gateway, fetches back proof + prove.log + report.json):
#   ./run prove-cluster GUEST=<name> BLOCK=<n> REMOTE=user@host [PORT=p] [MODE=m] [WITNESS=<path>]
#
# Examples:
#   ./run build-elf GUEST=fibonacci
#   ./run gen-input GUEST=fibonacci N=20
#   ./run prove  ELF=../../guests/fibonacci/fibonacci.elf INPUT=../../guests/fibonacci/inputs/n20.bin REMOTE=root@ssh.vast.ai PORT=12345
#   ./run verify ELF=../../guests/fibonacci/fibonacci.elf INPUT=../../guests/fibonacci/inputs/n20.bin PROOF=results/fibonacci/n20/<run>/proof.bin
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  sed -n '2,/^set -euo/p' "${BASH_SOURCE[0]}" | sed 's/^# \{0,1\}//; /^set -euo/d'
  exit "${1:-0}"
}

cmd="${1:-}"
[[ -z "$cmd" || "$cmd" == "-h" || "$cmd" == "--help" || "$cmd" == "help" ]] && usage 0
shift

# Parse KEY=VALUE tokens into the environment.
for kv in "$@"; do
  case "$kv" in
    *=*) export "${kv%%=*}=${kv#*=}" ;;
    *) echo "ERROR: bad argument '$kv' (expected KEY=VALUE)" >&2; exit 1 ;;
  esac
done

# Guest artifacts (ELF + inputs) live in the top-level guests/<name>/ folder
# (shared, prover-agnostic); run records stay in the infra dir. Overridable via env.
GUESTS_DIR="${GUESTS_DIR:-$ROOT/../../guests}"
OUT_DIR="${OUT_DIR:-$ROOT/results}"
RUNNER="${RUNNER:-$ROOT/sp1-runner/target/release/sp1-runner}"

# shellcheck source=/dev/null
source "$ROOT/scripts/core.sh"

# load_guest — source guests/<GUEST>/guest.sh (producers / decode only).
load_guest() {
  : "${GUEST:?set GUEST=<name> (see guests/)}"
  local f="$ROOT/guests/$GUEST/guest.sh"
  if [[ ! -f "$f" ]]; then
    echo "ERROR: unknown guest '$GUEST' — $f not found." >&2
    echo "Available guests:" >&2
    ls -1 "$ROOT/guests" 2>/dev/null | sed 's/^/  - /' >&2 || true
    exit 1
  fi
  # shellcheck source=/dev/null
  source "$f"
  declare -F guest_decode_pv >/dev/null || \
    guest_decode_pv() { echo "(no guest_decode_pv; hex dump of $1)"; xxd -l 256 "$1" || true; }
}

# abspath — resolve a path to absolute (relative to the invocation cwd).
abspath() { case "$1" in /*) echo "$1";; *) echo "$PWD/$1";; esac; }

case "$cmd" in
  build-elf)
    load_guest
    ELF="$GUESTS_DIR/$GUEST/$GUEST.elf"
    mkdir -p "$(dirname "$ELF")"
    guest_build_elf
    echo "ELF: $ELF"
    ;;
  gen-input)
    load_guest
    tag="$(guest_tag)"
    INPUT="$GUESTS_DIR/$GUEST/inputs/$tag.bin"
    mkdir -p "$(dirname "$INPUT")"
    guest_gen_input
    echo "Input: $INPUT ($(wc -c < "$INPUT") bytes)"
    # Auto-profile: if the ELF and local runner exist, run the zkVM execute to
    # produce the report (cycles/gas/opcodes) next to the input. Best-effort —
    # a failure here never invalidates the witness. Set NO_REPORT=1 to skip.
    ELF="$GUESTS_DIR/$GUEST/$GUEST.elf"
    if [[ -z "${NO_REPORT:-}" && -f "$ELF" && -x "$RUNNER" ]]; then
      execute_local || echo "WARN: report step failed (witness is still valid)"
    elif [[ -z "${NO_REPORT:-}" ]]; then
      echo "Note : ELF/runner missing — for the report later: ./run execute ELF=$ELF INPUT=$INPUT"
    fi
    echo "Next : ./run prove ELF=$ELF INPUT=$INPUT REMOTE=user@host PORT=p"
    ;;
  execute)
    ELF="$(abspath "${ELF:?set ELF=path to the guest ELF}")"
    INPUT="$(abspath "${INPUT:?set INPUT=path to the input file}")"
    execute_local
    ;;
  prove)
    ELF="$(abspath "${ELF:?set ELF=path to the guest ELF}")"
    INPUT="$(abspath "${INPUT:?set INPUT=path to the input file}")"
    prove_remote
    ;;
  prove-cluster)
    # Uniform cluster-prove verb (driven by cli/prove-farm). Resolve this guest's ELF + witness
    # from GUEST/BLOCK, force the NETWORK backend (the 16-GPU gateway, not single-box cuda that
    # plain `prove` defaults to), then prove + fetch the run record via prove_remote.
    : "${GUEST:?set GUEST=<name>}" "${BLOCK:?set BLOCK=<n>}"
    tag="${CHAIN_ID:-1}-$BLOCK"
    ELF="$GUESTS_DIR/$GUEST/$GUEST.elf"
    INPUT="${WITNESS:-$GUESTS_DIR/$GUEST/fixtures/$tag.bin}"
    [[ -f "$INPUT" ]] || INPUT="$GUESTS_DIR/$GUEST/inputs/$tag.bin"
    ELF="$(abspath "$ELF")"; INPUT="$(abspath "$INPUT")"
    REMOTE_PROVER="${REMOTE_PROVER:-network}"   # → cluster via the network-gateway
    prove_remote
    ;;
  verify)
    ELF="$(abspath "${ELF:?set ELF=path to the guest ELF}")"
    INPUT="$(abspath "${INPUT:?set INPUT=path to the input file}")"
    PROOF="$(abspath "${PROOF:?set PROOF=path to the proof file}")"
    verify_local
    ;;
  decode-pv)
    load_guest
    : "${PV:?set PV=path to a public-values file}"
    [[ -f "$PV" ]] || { echo "ERROR: PV not found: $PV" >&2; exit 1; }
    guest_decode_pv "$(abspath "$PV")"
    ;;
  *)
    echo "ERROR: unknown command '$cmd'" >&2
    usage 1
    ;;
esac
