#!/usr/bin/env bash
#
# run — dispatcher for the ZisK proving pipeline.
#
# Same split as the SP1 infra:
#   * PRODUCERS (guest-aware): build the ELF / generate the witness. They take a
#     GUEST and its params, because building/generating is guest-specific. They
#     run LOCALLY (on the Mac) — the remote box only proves.
#   * CONSUMERS (generic, file-based): execute / prove / verify operate on explicit
#     artifact PATHS — they never regenerate anything, so they take no guest params.
#
# ZisK specifics vs SP1:
#   * The runner is a SHELL wrapper (./zisk-runner) around the cargo-zisk / ziskemu
#     CLI, not a compiled binary. It emits the SAME report.json schema as sp1-runner.
#   * A witness is a PAIR: <tag>.bin (the input) + <tag>.hints (ZisK "hints").
#     The hints path is derived from the input by convention (sibling .hints).
#   * Proving needs a one-time per-ELF `cargo-zisk setup` ON THE BOX — see
#     cluster/01-setup-elf.sh. It is not a per-block step and is not in `run`.
#
# Producers (guests/<name>/guest.sh provides build_elf / gen_input / decode_pv):
#   ./run build-elf GUEST=<name> [KEY=VALUE ...]        -> ../../guests/<name>/<name>.elf
#   ./run gen-input GUEST=<name> [KEY=VALUE ...] [NO_REPORT=1]
#       -> ../../guests/<name>/inputs/<tag>.bin (+ <tag>.hints)
#       (by default, if the ELF + runner exist, also writes the execution report
#        next to the input; NO_REPORT=1 skips that step)
#   ./run decode-pv GUEST=<name> PV=<path>              (pretty-print public values)
#
# Consumers (explicit paths, no GUEST):
#   ./run execute ELF=<path> INPUT=<path>            (local emulation -> report + pv)
#   ./run prove   ELF=<path> INPUT=<path> REMOTE=user@host [PORT=p] [MODE=m] [HINTS=<path>]
#   ./run verify  ELF=<path> INPUT=<path> PROOF=<path>
#   ./run prove-cluster GUEST=<name> BLOCK=<n> REMOTE=user@host [PORT=p] [MODE=m] [WITNESS=<path>]
#       (uniform cluster-prove — resolves the guest's ELF+witness+sibling .hints; prove_remote's
#        default backend is the coordinator/cluster; driven by cli/prove-farm)
#
# Examples:
#   ./run build-elf GUEST=zisk-reth ZISK_ETH_DIR=../../vendor/zisk-eth-client
#   ./run gen-input GUEST=zisk-reth ZISK_ETH_DIR=../../vendor/zisk-eth-client BLOCK=20000000 RPC_URL=https://…
#   ./run prove  ELF=../../guests/zisk-reth/zisk-reth.elf INPUT=../../guests/zisk-reth/inputs/1-20000000.bin REMOTE=root@ssh.vast.ai PORT=12345
#   ./run verify ELF=../../guests/zisk-reth/zisk-reth.elf INPUT=../../guests/zisk-reth/inputs/1-20000000.bin PROOF=results/zisk-reth/1-20000000/…/proof.bin
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  sed -n '2,/^set -euo/p' "${BASH_SOURCE[0]}" | sed 's/^# \{0,1\}//; /^set -euo/d'
  exit "${1:-0}"
}

cmd="${1:-}"
[[ -z "$cmd" || "$cmd" == "-h" || "$cmd" == "--help" || "$cmd" == "help" ]] && usage 0
shift

# Parse KEY=VALUE tokens into the environment.
for kv in "$@"; do
  case "$kv" in
    *=*) export "${kv%%=*}=${kv#*=}" ;;
    *) echo "ERROR: bad argument '$kv' (expected KEY=VALUE)" >&2; exit 1 ;;
  esac
done

# Guest artifacts (ELF + inputs) live in the top-level guests/<name>/ folder
# (shared, prover-agnostic); run records stay in the infra dir. Overridable via env.
GUESTS_DIR="${GUESTS_DIR:-$ROOT/../../guests}"
OUT_DIR="${OUT_DIR:-$ROOT/results}"
RUNNER="${RUNNER:-$ROOT/zisk-runner}"

# shellcheck source=/dev/null
source "$ROOT/scripts/core.sh"

# load_guest — source guests/<GUEST>/guest.sh (producers / decode only).
load_guest() {
  : "${GUEST:?set GUEST=<name> (see guests/)}"
  local f="$ROOT/guests/$GUEST/guest.sh"
  if [[ ! -f "$f" ]]; then
    echo "ERROR: unknown guest '$GUEST' — $f not found." >&2
    echo "Available guests:" >&2
    ls -1 "$ROOT/guests" 2>/dev/null | sed 's/^/  - /' >&2 || true
    exit 1
  fi
  # shellcheck source=/dev/null
  source "$f"
  declare -F guest_decode_pv >/dev/null || \
    guest_decode_pv() { echo "(no guest_decode_pv; hex dump of $1)"; xxd -l 256 "$1" || true; }
}

# abspath — resolve a path to absolute (relative to the invocation cwd).
abspath() { case "$1" in /*) echo "$1";; *) echo "$PWD/$1";; esac; }

case "$cmd" in
  build-elf)
    load_guest
    ELF="$GUESTS_DIR/$GUEST/$GUEST.elf"
    mkdir -p "$(dirname "$ELF")"
    guest_build_elf
    echo "ELF: $ELF"
    ;;
  gen-input)
    load_guest
    tag="$(guest_tag)"
    INPUT="$GUESTS_DIR/$GUEST/inputs/$tag.bin"
    HINTS="${INPUT%.bin}.hints"
    mkdir -p "$(dirname "$INPUT")"
    guest_gen_input
    echo "Input: $INPUT ($(wc -c < "$INPUT") bytes)"
    [[ -e "$HINTS" ]] && echo "Hints: $HINTS"
    # Auto-profile: if the ELF and local runner exist, run the zkVM emulation to
    # produce the report (steps) next to the input. Best-effort — a failure here
    # never invalidates the witness. Set NO_REPORT=1 to skip.
    ELF="$GUESTS_DIR/$GUEST/$GUEST.elf"
    if [[ -z "${NO_REPORT:-}" && -f "$ELF" && -x "$RUNNER" ]]; then
      execute_local || echo "WARN: report step failed (witness is still valid)"
    elif [[ -z "${NO_REPORT:-}" ]]; then
      echo "Note : ELF/runner missing — for the report later: ./run execute ELF=$ELF INPUT=$INPUT"
    fi
    echo "Next : ./run prove ELF=$ELF INPUT=$INPUT REMOTE=user@host PORT=p"
    ;;
  execute)
    ELF="$(abspath "${ELF:?set ELF=path to the guest ELF}")"
    INPUT="$(abspath "${INPUT:?set INPUT=path to the input file}")"
    execute_local
    ;;
  prove)
    ELF="$(abspath "${ELF:?set ELF=path to the guest ELF}")"
    INPUT="$(abspath "${INPUT:?set INPUT=path to the input file}")"
    [[ -n "${HINTS:-}" ]] && HINTS="$(abspath "$HINTS")"
    prove_remote
    ;;
  prove-cluster)
    # Uniform cluster-prove verb (driven by cli/prove-farm). Resolve this guest's ELF + witness
    # (+ sibling .hints) from GUEST/BLOCK, then prove + fetch via prove_remote — whose default
    # backend is already the coordinator (cluster), not a single local prover.
    : "${GUEST:?set GUEST=<name>}" "${BLOCK:?set BLOCK=<n>}"
    tag="${CHAIN_ID:-1}-$BLOCK"
    ELF="$GUESTS_DIR/$GUEST/$GUEST.elf"
    INPUT="${WITNESS:-$GUESTS_DIR/$GUEST/fixtures/$tag.bin}"
    [[ -f "$INPUT" ]] || INPUT="$GUESTS_DIR/$GUEST/inputs/$tag.bin"
    ELF="$(abspath "$ELF")"; INPUT="$(abspath "$INPUT")"
    [[ -z "${HINTS:-}" && -f "${INPUT%.bin}.hints" ]] && HINTS="${INPUT%.bin}.hints"
    [[ -n "${HINTS:-}" ]] && HINTS="$(abspath "$HINTS")"
    prove_remote
    ;;
  verify)
    ELF="$(abspath "${ELF:?set ELF=path to the guest ELF}")"
    INPUT="$(abspath "${INPUT:?set INPUT=path to the input file}")"
    PROOF="$(abspath "${PROOF:?set PROOF=path to the proof file}")"
    verify_local
    ;;
  decode-pv)
    load_guest
    : "${PV:?set PV=path to a public-values file}"
    [[ -f "$PV" ]] || { echo "ERROR: PV not found: $PV" >&2; exit 1; }
    guest_decode_pv "$(abspath "$PV")"
    ;;
  *)
    echo "ERROR: unknown command '$cmd'" >&2
    usage 1
    ;;
esac
